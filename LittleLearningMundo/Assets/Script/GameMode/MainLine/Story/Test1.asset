  m_Script: {fileID: 11500000, guid: 3b48a1cd78c958a47879bfae4783ab30, type: 3}
  m_Name: Test1
  m_EditorClassIdentifier: 
  storyTitle: "\u65B0\u751F\u5165\u5B78\u5C0E\u89BD"
  steps:
  - locationID: OPHY
    customDialogue: "\u6210\u5927\u7269\u7406\u7CFB\u820A\u9928\u4F4D\u65BC\u570B\u7ACB\u6210\u529F\u5927\u5B78\u6210\u529F\u6821\u5340\u5167\uFF0C\u662F\u7269\u7406\u5B78\u7CFB\u65E9\u671F\u4F7F\u7528\u7684\u91CD\u8981\u5EFA\u7BC9\u4E4B\u4E00\u3002\u9019\u68DF\u5EFA\u7BC9\u4E3B\u8981\u627F\u64D4\u904E\u6559\u5B78\u8207\u7814\u7A76\u529F\u80FD\uFF0C\u898B\u8B49\u4E86\u6210\u5927\u7269\u7406\u7CFB\u5F9E\u57FA\u790E\u6559\u5B78\u5230\u7814\u7A76\u767C\u5C55\u7684\u6B77\u7A0B\u3002\n\n\u7269\u7406\u7CFB\u820A\u9928\u5C6C\u65BC\u8F03\u65E9\u671F\u7684\u6821\u5712\u5EFA\u7BC9\uFF0C\u5916\u89C0\u98A8\u683C\u6A38\u5BE6\uFF0C\u4EE5\u6C34\u6CE5\u7D50\u69CB\u70BA\u4E3B\uFF0C\u7A97\u6236\u6392\u5217\u6574\u9F4A\uFF0C\u6574\u9AD4\u8A2D\u8A08\u504F\u5411\u5BE6\u7528\u800C\u975E\u73FE\u4EE3\u5316\u3002\u8207\u5F8C\u671F\u8208\u5EFA\u7684\u65B0\u5F0F\u7814\u7A76\u5927\u6A13\u76F8\u6BD4\uFF0C\u820A\u9928\u5728\u8A2D\u5099\u8207\u7A7A\u9593\u914D\u7F6E\u4E0A\u8F03\u70BA\u50B3\u7D71\uFF0C\u4F46\u4ECD\u5177\u6709\u9AD8\u5EA6\u6B77\u53F2\u610F\u7FA9\u3002\n\n\u5728\u65E9\u671F\uFF0C\u8A31\u591A\u666E\u901A\u7269\u7406\u8AB2\u7A0B\u8207\u57FA\u790E\u5BE6\u9A57\u8AB2\u90FD\u5728\u6B64\u9032\u884C\u3002\u9928\u5167\u66FE\u8A2D\u6709\u7269\u7406\u5BE6\u9A57\u5BA4\u3001\u6559\u5E2B\u7814\u7A76\u5BA4\u8207\u6559\u5B78\u7A7A\u9593\uFF0C\u5B78\u751F\u5728\u9019\u88E1\u5B78\u7FD2\u7D93\u5178\u7269\u7406\u3001\u9032\u884C\u5149\u5B78\u3001\u96FB\u5B78\u8207\u57FA\u790E\u91CF\u6E2C\u76F8\u95DC\u5BE6\u9A57\u3002\u5C0D\u4E0D\u5C11\u6821\u53CB\u800C\u8A00\uFF0C\u9019\u88E1\u662F\u7B2C\u4E00\u6B21\u63A5\u89F8\u5BE6\u9A57\u5100\u5668\u8207\u7269\u7406\u7814\u7A76\u7684\u5730\u65B9\u3002\n\n\u96A8\u8457\u7814\u7A76\u9818\u57DF\u8207\u8A2D\u5099\u9700\u6C42\u9010\u6F38\u63D0\u5347\uFF0C\u7269\u7406\u7CFB\u5F8C\u4F86\u589E\u8A2D\u6216\u8F49\u79FB\u90E8\u5206\u7814\u7A76\u7A7A\u9593\u81F3\u5176\u4ED6\u5EFA\u7BC9\uFF0C\u4F46\u820A\u9928\u4ECD\u4FDD\u7559\u5176\u8C61\u5FB5\u6027\u7684\u5730\u4F4D\uFF0C\u4EE3\u8868\u6210\u5927\u7269\u7406\u7CFB\u65E9\u671F\u767C\u5C55\u7684\u6838\u5FC3\u64DA\u9EDE\u3002\n\n\u6210\u5927\u7269\u7406\u7CFB\u7684\u7814\u7A76\u9818\u57DF\u6DB5\u84CB\u51DD\u614B\u7269\u7406\u3001\u5149\u96FB\u7269\u7406\u3001\u7406\u8AD6\u7269\u7406\u3001\u6750\u6599\u7269\u7406\u8207\u8A08\u7B97\u7269\u7406\u7B49\u65B9\u5411\uFF0C\u820A\u9928\u66FE\u662F\u9019\u4E9B\u7814\u7A76\u840C\u82BD\u8207\u6559\u5B78\u57FA\u790E\u5EFA\u7ACB\u7684\u91CD\u8981\u5834\u6240\u3002"
    useAISummary: 1
  - locationID: CSIE
    customDialogue: "\u6210\u5927\u8CC7\u5DE5\u7CFB\u4F4D\u65BC\u570B\u7ACB\u6210\u529F\u5927\u5B78\u6210\u529F\u6821\u5340\u5167\uFF0C\u96B8\u5C6C\u65BC\u8CC7\u8A0A\u5B78\u9662\uFF0C\u662F\u6821\u5167\u91CD\u8981\u7684\u5DE5\u7A0B\u8207\u8CC7\u8A0A\u9818\u57DF\u5B78\u7CFB\u4E4B\u4E00\u3002\u8CC7\u5DE5\u7CFB\u4E3B\u8981\u57F9\u990A\u5B78\u751F\u5728\u96FB\u8166\u79D1\u5B78\u8207\u8CC7\u8A0A\u5DE5\u7A0B\u65B9\u9762\u7684\u7406\u8AD6\u57FA\u790E\u8207\u5BE6\u52D9\u80FD\u529B\uFF0C\u6DB5\u84CB\u8EDF\u9AD4\u958B\u767C\u3001\u7CFB\u7D71\u8A2D\u8A08\u3001\u4EBA\u5DE5\u667A\u6167\u8207\u7DB2\u8DEF\u6280\u8853\u7B49\u65B9\u5411\u3002\n\n\u8CC7\u5DE5\u7CFB\u7684\u6559\u5B78\u5167\u5BB9\u5305\u542B\u8CC7\u6599\u7D50\u69CB\u3001\u6F14\u7B97\u6CD5\u3001\u4F5C\u696D\u7CFB\u7D71\u3001\u8A08\u7B97\u6A5F\u7D44\u7E54\u3001\u7A0B\u5F0F\u8A2D\u8A08\u3001\u8CC7\u6599\u5EAB\u7CFB\u7D71\u3001\u8A08\u7B97\u6A5F\u7DB2\u8DEF\u8207\u4EBA\u5DE5\u667A\u6167\u7B49\u6838\u5FC3\u8AB2\u7A0B\u3002\u5B78\u751F\u5728\u5927\u4E00\u8207\u5927\u4E8C\u591A\u4EE5\u57FA\u790E\u7406\u8AD6\u8207\u7A0B\u5F0F\u8A13\u7DF4\u70BA\u4E3B\uFF0C\u5927\u4E09\u4E4B\u5F8C\u5247\u9010\u6F38\u9032\u5165\u5C08\u984C\u88FD\u4F5C\u8207\u9032\u968E\u9078\u4FEE\u8AB2\u7A0B\u3002\n\n\u7814\u7A76\u9818\u57DF\u65B9\u9762\uFF0C\u8CC7\u5DE5\u7CFB\u6DB5\u84CB\u591A\u500B\u65B9\u5411\uFF0C\u4F8B\u5982\uFF1A\n\n\u4EBA\u5DE5\u667A\u6167\u8207\u6A5F\u5668\u5B78\u7FD2\n\n\u96FB\u8166\u8996\u89BA\u8207\u5F71\u50CF\u8655\u7406\n\n\u81EA\u7136\u8A9E\u8A00\u8655\u7406\n\n\u5206\u6563\u5F0F\u7CFB\u7D71\u8207\u96F2\u7AEF\u904B\u7B97\n\n\u7DB2\u8DEF\u8207\u8CC7\u8A0A\u5B89\u5168\n\n\u5D4C\u5165\u5F0F\u7CFB\u7D71\u8207\u7269\u806F\u7DB2\n\n\u9AD8\u6548\u80FD\u904B\u7B97\n\n\u8CC7\u5DE5\u7CFB\u5B78\u751F\u901A\u5E38\u9700\u8981\u9032\u884C\u5C08\u984C\u7814\u7A76\u6216\u5BE6\u52D9\u5C08\u6848\uFF0C\u57F9\u990A\u5F9E\u554F\u984C\u5206\u6790\u3001\u7CFB\u7D71\u8A2D\u8A08\u5230\u5BE6\u4F5C\u8207\u6E2C\u8A66\u7684\u5B8C\u6574\u80FD\u529B\u3002\u8A31\u591A\u5B78\u751F\u4E5F\u6703\u53C3\u8207\u7AF6\u8CFD\u3001\u5BE6\u9A57\u5BA4\u7814\u7A76\u6216\u7522\u5B78\u5408\u4F5C\u8A08\u756B\u3002\n\n\u8CC7\u5DE5\u7CFB\u8207\u96FB\u6A5F\u7CFB\u7684\u5DEE\u7570\u5728\u65BC\uFF0C\u8CC7\u5DE5\u7CFB\u66F4\u504F\u91CD\u65BC\u8EDF\u9AD4\u3001\u6F14\u7B97\u6CD5\u8207\u7CFB\u7D71\u5C64\u9762\u8A2D\u8A08\uFF0C\u800C\u96FB\u6A5F\u7CFB\u5247\u6DB5\u84CB\u8F03\u591A\u786C\u9AD4\u96FB\u8DEF\u8207\u96FB\u5B50\u5DE5\u7A0B\u5167\u5BB9\u3002\u4E0D\u904E\u5169\u8005\u5728\u5D4C\u5165\u5F0F\u7CFB\u7D71\u3001\u901A\u8A0A\u8207\u6676\u7247\u8A2D\u8A08\u7B49\u9818\u57DF\u6703\u6709\u91CD\u758A\u3002"
    useAISummary: 1
